generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int        @id @default(autoincrement())
  name         String
  costPrice    Int        // Harga Modal
  sellingPrice Int        // Harga Jual
  stock        Int        // Ketersediaan Stok
  saleItems    SaleItem[]
}

model Sale {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  totalAmount Int
  cashGiven   Int
  change      Int
  cashierName String     // Menyimpan nama kasir
  items       SaleItem[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  price     Int     
  sale      Sale    @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}